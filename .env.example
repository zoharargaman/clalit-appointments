CLALIT_USER_ID=your_id_number
CLALIT_USERNAME=your_username
CLALIT_PASSWORD=your_password

# CAPTCHA_PROVIDER selects the captcha solver: nvidia (default), azcaptcha, or manual
CAPTCHA_PROVIDER=nvidia

# NVIDIA API key for Llama 3.2 Vision captcha solving (primary solver)
# Get one at https://build.nvidia.com/explore/
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AzCaptcha API key (fallback when NVIDIA fails after 5 error retries)
# Get one at https://azcaptcha.com
AZCAPTCHA_API_KEY=your_azcaptcha_key
